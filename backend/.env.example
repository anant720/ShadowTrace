# ShadowTrace Backend — Environment Configuration
# Copy to .env and fill in values

# MongoDB
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=ShadowTrace
MONGO_DB_NAME=shadowtrace

# Security
API_KEY=shadowtrace-dev-key
CORS_ORIGINS=["http://localhost:3000","chrome-extension://*"]

# JWT Authentication
JWT_SECRET=your-super-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Admin Credentials (seeded on first boot)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-immediately

# Rate Limiting
RATE_LIMIT_RPM=60

# Logging
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# ML Anomaly Detection
ANOMALY_INTERVAL_MINUTES=15
ANOMALY_ZSCORE_THRESHOLD=2.0
